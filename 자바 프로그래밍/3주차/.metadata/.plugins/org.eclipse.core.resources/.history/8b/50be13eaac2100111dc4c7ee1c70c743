package ai.weak_3for;

public class Weak3for_01 {

	public static void main(String[] args) {
		// 1부터 10까지합 짝수합 홀수합 출력
		int i = 1,sum_j=0,sum_h=0;
		while(i<=10) {
			switch(i%2) {
			case 0:
				sum_j+=i;
				break;
			default:
				sum_h+=i;
			}
			i++;
		}
		System.out.println("짝수합은 "+sum_j+" 홀수합은 "+sum_h);
	}

}
